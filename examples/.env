# Fichier d’exemple pour les scripts sous examples/ — ne contient pas de secrets.
# Chemin du journal JSONL (relatif au répertoire de travail courant lors du lancement, souvent la racine du dépôt ;
# le dossier de logs est en pratique examples/logs/, homologue de « exemples/logs » dans ce dépôt anglophone).
TIVINS_LLAMA_CONVERSATION_LOG=examples/logs/example.session.jsonl

# Décommenter pour désactiver les séquences ANSI (consoles anciennes sous Windows sans support VT).
# TIVINS_LLAMA_NO_ANSI=1

# Décommenter pour afficher aussi le bloc reasoning sur stdout (au lieu du stderr par défaut).
# TIVINS_LLAMA_REASONING_STDOUT=1

# Décommenter pour que print_output() affiche le dump verbeux hérité au lieu du HumanTurnRenderer.
# TIVINS_LLAMA_COMPLETION_DUMP_RAW=1
