{
    "name": "tivins/llm-php",
    "version": "1.20.2",
    "license": "MIT",
    "description": "PHP library for local LLMs",
    "keywords": ["llm", "local", "llama", "php"],
    "homepage": "https://github.com/tivins/llm-php",
    "readme": "README.md",
    "autoload": {
        "psr-4": {
            "Tivins\\Llama\\": "src/Tivins/Llama"
        }
    },
    "authors": [
        {
            "name": "Tivins"
        }
    ],
    "minimum-stability": "stable",
    "require": {
      "ext-curl": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "phpstan": "vendor/bin/phpstan analyse"
    }
}
